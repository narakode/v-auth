---
const { tag: Tag = 'input', type = 'text', ...attrs } = Astro.props;
---

<Tag
  {...attrs}
  type={Tag === 'input' ? type : null}
  class={`
        border border-slate-300 rounded-md placeholder-slate-400 text-slate-900
        ${type === 'file' ? 'file:bg-slate-200 file:py-2 file:px-3 file:border-r file:border-slate-300 file:mr-3 pr-3 focus:outline-red-700' : 'py-2 px-3'}
        focus:border-red-700 focus:ring-red-700
    `}
/>

<script>
  const inputCountChars =
    document.querySelectorAll<HTMLInputElement>('[data-count-chars]');

  inputCountChars.forEach((input) => {
    const countCharsEl = document.querySelector(
      `#${input.id}-count-chars`,
    ) as HTMLSpanElement;

    input.addEventListener('input', (e) => {
      countCharsEl.innerText =
        input.value.length < 1 ? '' : `${input.value.length}`;
    });
  });
</script>
