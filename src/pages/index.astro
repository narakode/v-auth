---
import { Icon } from "astro-icon/components"

const tools = [
	{
		name: 'Google Search Result Preview',
		description: 'Preview your page in google search result',
		icon: 'tabler:world-search'
	},
	{
		name: 'Open Graph Preview',
		description: 'Preview your page in all media sites',
		icon: 'tabler:photo-alt'
	},
	{
		name: 'SEO HTML Head Meta Tag Generator',
		description: 'Generate SEO HTML code for head meta tag',
		icon: 'tabler:file-code'
	},
]
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Astro</title>
	</head>
	<body>
		<h1>Free Seo Tools</h1>

		<main>
			{tools.map(tool => <div>
				<Icon name={tool.icon} />
				<h2>{tool.name}</h2>
				<p>{tool.description}</p>
			</div>)}
		</main>
	</body>
</html>
